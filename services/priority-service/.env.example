PORT=3003
TICKET_SERVICE_URL=http://ticket-service:3001

# LLM Provider — pick one: gemini | openai | anthropic
LLM_PROVIDER=gemini

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (alternative)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional Slack notification after each priority run
SLACK_BOT_TOKEN=xoxb-...
SLACK_NOTIFY_CHANNEL=#engineering

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=30
