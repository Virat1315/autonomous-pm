PORT=3001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000

# ── Choose your database backend ──────────────────────────────────────────────
DATABASE_BACKEND=mongo   # "mongo" | "sql"

# MongoDB Atlas (used when DATABASE_BACKEND=mongo)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DBNAME=autonomous_pm

# PostgreSQL / SQLite (used when DATABASE_BACKEND=sql)
DATABASE_URL=postgresql://apm_user:apm_password@localhost:5432/autonomous_pm
# DATABASE_URL=sqlite+aiosqlite:///./dev.db   # local dev without Docker
