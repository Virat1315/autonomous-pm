# ── Autonomous PM – Environment Variables ─────────────────────────────────────
# Copy to .env and fill in your values. NEVER commit .env to git.

# ── LLM Provider (pick ONE) ───────────────────────────────────────────────────
# Options: openai | anthropic | gemini
LLM_PROVIDER=gemini

# Google Gemini (recommended – generous free tier)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic (alternative)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Slack (optional – enables Slack intake + standup posting) ─────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_STANDUP_CHANNEL=#standup
SLACK_NOTIFY_CHANNEL=#dev-updates
WATCHED_CHANNELS=

# ── GitHub (optional – enables PR/commit → ticket status sync) ────────────────
GITHUB_WEBHOOK_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB (if using MongoDB instead of PostgreSQL)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/autonomous_pm

# PostgreSQL (default when using docker-compose)
DATABASE_URL=postgresql://apm_user:apm_password@localhost:5432/autonomous_pm
